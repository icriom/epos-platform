generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organisation {
  id                 String    @id @default(uuid())
  name               String
  legalName          String
  vatNumber          String?
  companyNumber      String?
  addressLine1       String
  addressLine2       String?
  city               String
  postcode           String
  country            String    @default("GB")
  phone              String?
  email              String
  logoUrl            String?
  subscriptionTier   String    @default("TRIAL")
  subscriptionStatus String    @default("ACTIVE")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  venues             Venue[]

  @@map("organisations")
}

model Venue {
  id              String       @id @default(uuid())
  organisationId  String
  name            String
  addressLine1    String
  addressLine2    String?
  city            String
  postcode        String
  phone           String?
  email           String?
  vatNumber       String?
  logoUrl         String?
  receiptHeader   String?
  receiptFooter   String?
  defaultCurrency String       @default("GBP")
  timezone        String       @default("Europe/London")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  organisation    Organisation @relation(fields: [organisationId], references: [id])
  locations       Location[]
  staff           Staff[]
  devices         Device[]
  menus           Menu[]

  @@map("venues")
}

model Location {
  id               String    @id @default(uuid())
  venueId          String
  name             String
  description      String?
  defaultVatType   String    @default("EAT_IN")
  serviceChargePct Decimal?
  isActive         Boolean   @default(true)
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  venue            Venue     @relation(fields: [venueId], references: [id])

  @@map("locations")
}

model Staff {
  id               String       @id @default(uuid())
  venueId          String
  firstName        String
  lastName         String
  displayName      String
  email            String?
  pinHash          String
  roleId           String?
  photoUrl         String?
  isActive         Boolean      @default(true)
  backOfficeAccess Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  venue            Venue        @relation(fields: [venueId], references: [id])
  role             Role?        @relation(fields: [roleId], references: [id])
  clockEvents      ClockEvent[]

  @@map("staff")
}

model Device {
  id                String    @id @default(uuid())
  venueId           String
  name              String
  type              String
  platform          String    @default("ANDROID")
  model             String?
  osVersion         String?
  appVersion        String?
  lastSeenAt        DateTime?
  lastSyncAt        DateTime?
  isOnline          Boolean   @default(false)
  offlineSince      DateTime?
  registrationToken String
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  venue             Venue     @relation(fields: [venueId], references: [id])

  @@map("devices")
}

model Menu {
  id          String         @id @default(uuid())
  venueId     String
  name        String
  description String?
  isActive    Boolean        @default(true)
  isDefault   Boolean        @default(false)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  venue       Venue          @relation(fields: [venueId], references: [id])
  categories  MenuCategory[]
  schedules   MenuSchedule[]

  @@map("menus")
}

model MenuSchedule {
  id         String   @id @default(uuid())
  menuId     String
  locationId String?
  daysOfWeek String[]
  startTime  String
  endTime    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  menu       Menu     @relation(fields: [menuId], references: [id])

  @@map("menu_schedules")
}

model MenuCategory {
  id               String         @id @default(uuid())
  menuId           String
  name             String
  description      String?
  colour           String?
  icon             String?
  sortOrder        Int            @default(0)
  defaultCourse    String?
  parentCategoryId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  menu             Menu           @relation(fields: [menuId], references: [id])
  parentCategory   MenuCategory?  @relation("SubCategories", fields: [parentCategoryId], references: [id])
  subCategories    MenuCategory[] @relation("SubCategories")
  items            MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id             String                  @id @default(uuid())
  venueId        String
  categoryId     String
  name           String
  description    String?
  pluCode        String
  barcode        String?
  basePrice      Decimal                 @db.Decimal(10, 2)
  costPrice      Decimal?                @db.Decimal(10, 2)
  vatType        String                  @default("EAT_IN")
  vatRate        Decimal                 @db.Decimal(5, 2)
  course         String?
  kitchenStation String?
  prepTimeMins   Int?
  imageUrl       String?
  isAvailable    Boolean                 @default(true)
  isArchived     Boolean                 @default(false)
  sortOrder      Int                     @default(0)
  calories       Int?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?
  category       MenuCategory            @relation(fields: [categoryId], references: [id])
  allergens      MenuItemAllergen[]
  modifierGroups MenuItemModifierGroup[]
  prices         MenuItemPrice[]

  @@map("menu_items")
}

model MenuItemAllergen {
  id         String   @id @default(uuid())
  menuItemId String
  allergen   String
  createdAt  DateTime @default(now())
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("menu_item_allergens")
}

model ModifierGroup {
  id            String                  @id @default(uuid())
  venueId       String
  name          String
  minSelections Int                     @default(0)
  maxSelections Int                     @default(1)
  isRequired    Boolean                 @default(false)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  deletedAt     DateTime?
  options       ModifierOption[]
  menuItems     MenuItemModifierGroup[]

  @@map("modifier_groups")
}

model ModifierOption {
  id              String        @id @default(uuid())
  modifierGroupId String
  name            String
  priceAdjustment Decimal       @default(0) @db.Decimal(10, 2)
  isAvailable     Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@map("modifier_options")
}

model MenuItemModifierGroup {
  id              String        @id @default(uuid())
  menuItemId      String
  modifierGroupId String
  sortOrder       Int           @default(0)
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id])
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id])

  @@map("menu_item_modifier_groups")
}

model PriceLevel {
  id          String          @id @default(uuid())
  venueId     String
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  prices      MenuItemPrice[]

  @@map("price_levels")
}

model MenuItemPrice {
  id           String     @id @default(uuid())
  menuItemId   String
  priceLevelId String
  locationId   String?
  price        Decimal    @db.Decimal(10, 2)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])
  priceLevel   PriceLevel @relation(fields: [priceLevelId], references: [id])

  @@map("menu_item_prices")
}

model Role {
  id          String   @id @default(uuid())
  venueId     String?
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  staff       Staff[]

  @@map("roles")
}

model ClockEvent {
  id        String   @id @default(uuid())
  staffId   String
  venueId   String
  sessionId String?
  eventType String
  eventAt   DateTime @default(now())
  deviceId  String?
  createdAt DateTime @default(now())
  staff     Staff    @relation(fields: [staffId], references: [id])

  @@map("clock_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  venueId    String
  staffId    String?
  deviceId   String?
  sessionId  String?
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  reason     String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

model TradingSession {
  id              String    @id @default(uuid())
  venueId         String
  locationId      String?
  openedBy        String
  closedBy        String?
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  status          String    @default("OPEN")
  cashFloatAmount Decimal?  @db.Decimal(10, 2)
  cashDeclared    Decimal?  @db.Decimal(10, 2)
  cashExpected    Decimal?  @db.Decimal(10, 2)
  cashVariance    Decimal?  @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("trading_sessions")
}

model Order {
  id            String      @id @default(uuid())
  venueId       String
  locationId    String?
  sessionId     String
  deviceId      String?
  staffId       String
  tableId       String?
  orderNumber   Int
  orderType     String      @default("TABLE")
  status        String      @default("OPEN")
  covers        Int?
  tabName       String?
  notes         String?
  subtotal      Decimal     @default(0) @db.Decimal(10, 2)
  vatTotal      Decimal     @default(0) @db.Decimal(10, 2)
  discountTotal Decimal     @default(0) @db.Decimal(10, 2)
  serviceCharge Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @default(0) @db.Decimal(10, 2)
  amountPaid    Decimal     @default(0) @db.Decimal(10, 2)
  openedAt      DateTime    @default(now())
  firstSentAt   DateTime?
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
  payments      Payment[]
  discounts     Discount[]

  @@map("orders")
}

model OrderItem {
  id              String              @id @default(uuid())
  orderId         String
  menuItemId      String
  menuItemName    String
  course          String?
  quantity        Int                 @default(1)
  unitPrice       Decimal             @db.Decimal(10, 2)
  vatType         String              @default("EAT_IN")
  vatRate         Decimal             @db.Decimal(5, 2)
  vatAmount       Decimal             @db.Decimal(10, 2)
  lineTotal       Decimal             @db.Decimal(10, 2)
  notes           String?
  status          String              @default("PENDING")
  sentAt          DateTime?
  voidReason      String?
  voidedBy        String?
  voidedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  order           Order               @relation(fields: [orderId], references: [id])
  modifiers       OrderItemModifier[]

  @@map("order_items")
}

model OrderItemModifier {
  id               String    @id @default(uuid())
  orderItemId      String
  modifierOptionId String
  optionName       String
  priceAdjustment  Decimal   @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())
  orderItem        OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("order_item_modifiers")
}

model Payment {
  id                String   @id @default(uuid())
  orderId           String
  sessionId         String
  staffId           String
  deviceId          String?
  amount            Decimal  @db.Decimal(10, 2)
  method            String
  status            String   @default("PENDING")
  currency          String   @default("GBP")
  tipAmount         Decimal  @default(0) @db.Decimal(10, 2)
  serviceCharge     Decimal  @default(0) @db.Decimal(10, 2)
  serviceChargeType String?
  cardScheme        String?
  cardLastFour      String?
  terminalId        String?
  transactionRef    String?
  authorisationCode String?
  isContactless     Boolean?
  isSoftpos         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  order             Order    @relation(fields: [orderId], references: [id])
  refunds           Refund[]

  @@map("payments")
}

model Refund {
  id           String   @id @default(uuid())
  paymentId    String
  orderId      String
  processedBy  String
  authorisedBy String?
  amount       Decimal  @db.Decimal(10, 2)
  refundType   String
  method       String
  reason       String?
  createdAt    DateTime @default(now())
  payment      Payment  @relation(fields: [paymentId], references: [id])

  @@map("refunds")
}

model Discount {
  id           String   @id @default(uuid())
  orderId      String
  orderItemId  String?
  appliedBy    String
  authorisedBy String?
  discountType String
  value        Decimal  @db.Decimal(10, 2)
  amountSaved  Decimal  @db.Decimal(10, 2)
  reason       String?
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id])

  @@map("discounts")
}

model TablePlan {
  id         String        @id @default(uuid())
  venueId    String
  locationId String
  name       String
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  tables     TableLayout[]

  @@map("table_plans")
}

model TableLayout {
  id                  String      @id @default(uuid())
  tablePlanId         String
  tableNumber         String
  covers              Int
  shape               String      @default("SQUARE")
  posX                Decimal     @db.Decimal(8, 2)
  posY                Decimal     @db.Decimal(8, 2)
  width               Decimal     @db.Decimal(8, 2)
  height              Decimal     @db.Decimal(8, 2)
  rotation            Int         @default(0)
  isActive            Boolean     @default(true)
  inactivityAlertMins Int?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  tablePlan           TablePlan   @relation(fields: [tablePlanId], references: [id])
  notes               TableNote[]

  @@map("table_layouts")
}

model TableNote {
  id           String      @id @default(uuid())
  tableId      String
  sessionId    String?
  createdBy    String
  note         String
  isPersistent Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  table        TableLayout @relation(fields: [tableId], references: [id])

  @@map("table_notes")
}
